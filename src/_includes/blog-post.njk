---
layout: base.njk
---

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8 text-center">
            {% for tag in tags %}
                <span class="badge bg-secondary mb-2">{{ tag }}</span>
            {% endfor %}

            <h1 class="display-4 fw-bold" style="color: #341830;">{{ title }}</h1>
            <p class="text-muted fst-italic">{{ date | readableDate }}</p>
            <hr class="my-4" style="width: 50px; margin: 0 auto; border-top: 3px solid #341830;">
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7 article-content fs-5 lh-lg">
            {{ content | safe }}
        </div>
    </div>

    <div class="row justify-content-center mt-5 pt-5 border-top">
        <div class="col-lg-8">
            <div class="list-group">
                <h4>En lien avec cela... </h3>
                {% for post in related %}
                    <a href="{{ collection.url.post }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-muted"></small><br>
                            <strong>{{ post }}</strong>
                        </div>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                {% endfor %}
            </div>
        </div>
        <iframe src="https://tommyroy.substack.com/embed" width="480" height="150" frameborder="0" scrolling="no"></iframe>
    </div>
</div>